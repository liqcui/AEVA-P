# AEVA Bench Service Configuration

# API Settings
API_V1_STR=/v1
PROJECT_NAME=AEVA Bench Service
VERSION=0.1.0

# Server
HOST=0.0.0.0
PORT=8001

# Database
DATABASE_URL=postgresql://aeva:aeva@localhost:5432/bench_service

# Security
API_KEY=your-api-key-here
SECRET_KEY=your-secret-key-here-change-in-production

# Logging
LOG_LEVEL=INFO

# Benchmark Settings
MAX_BENCHMARK_NAME_LENGTH=255
MAX_BENCHMARKS_PER_PAGE=100
DEFAULT_PAGE_SIZE=50
BENCHMARK_TIMEOUT=3600
MAX_CONCURRENT_BENCHMARKS=10

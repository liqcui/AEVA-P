# Auto Service Configuration

# API Configuration
API_V1_STR=/v1
PROJECT_NAME=AEVA Auto Service

# Database Configuration
DATABASE_URL=postgresql://aeva:aeva@localhost:5432/auto_service

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Service URLs
BENCH_SERVICE_URL=http://localhost:8001
GUARD_SERVICE_URL=http://localhost:8002
BRAIN_SERVICE_URL=http://localhost:8004

# Pipeline Configuration
DEFAULT_TIMEOUT=3600
MAX_RETRIES=3
RETRY_DELAY=60

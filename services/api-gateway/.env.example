# API Gateway Configuration

# API Configuration
API_V1_STR=/api/v1
PROJECT_NAME=AEVA API Gateway

# Service URLs
BENCH_SERVICE_URL=http://localhost:8001
GUARD_SERVICE_URL=http://localhost:8002
AUTO_SERVICE_URL=http://localhost:8003
BRAIN_SERVICE_URL=http://localhost:8004

# Gateway Configuration
REQUEST_TIMEOUT=300
MAX_RETRIES=3
RETRY_DELAY=1

# Rate Limiting
ENABLE_RATE_LIMITING=true
RATE_LIMIT_PER_MINUTE=100

# Authentication (future)
ENABLE_AUTH=false
JWT_SECRET_KEY=change-this-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS
CORS_ORIGINS=["*"]

# Logging
LOG_LEVEL=INFO

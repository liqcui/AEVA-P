# Brain Service Configuration

# API Configuration
API_V1_STR=/v1
PROJECT_NAME=AEVA Brain Service

# Database Configuration
DATABASE_URL=postgresql://aeva:aeva@localhost:5432/brain_service

# LLM Configuration
LLM_PROVIDER=openai
LLM_MODEL=gpt-4
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# Service URLs
BENCH_SERVICE_URL=http://localhost:8001
GUARD_SERVICE_URL=http://localhost:8002

# Analysis Configuration
MAX_CONTEXT_LENGTH=8000
ENABLE_CACHING=true
CACHE_TTL=3600

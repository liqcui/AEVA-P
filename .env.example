# AEVA Environment Variables
# Copy this file to .env and fill in your values

# Anthropic Claude API Key (required for AEVA-Brain)
AEVA_BRAIN_API_KEY=your_claude_api_key_here

# Database Configuration
AEVA_DB_HOST=localhost
AEVA_DB_PORT=5432
AEVA_DB_NAME=aeva
AEVA_DB_USER=aeva
AEVA_DB_PASSWORD=your_db_password_here

# Redis Configuration
AEVA_REDIS_HOST=localhost
AEVA_REDIS_PORT=6379
AEVA_REDIS_PASSWORD=

# General Settings
AEVA_LOG_LEVEL=INFO
AEVA_DEBUG=false
